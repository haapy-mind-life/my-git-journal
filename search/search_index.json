{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"]},"docs":[{"location":"","title":"Welcome to My Git Journal","text":""},{"location":"2024-12-21-%231/","title":"Git \ucd08\ubcf4\uc790\ub97c \uc704\ud55c \uac00\uc774\ub4dc","text":"<p>Git\uc740 \uc18c\ud504\ud2b8\uc6e8\uc5b4 \uac1c\ubc1c\uc5d0\uc11c \ud611\uc5c5\uacfc \ubc84\uc804 \uad00\ub9ac\ub97c \uc704\ud55c \ub3c4\uad6c\uc785\ub2c8\ub2e4. \uc774\ub97c \uc0ac\uc6a9\ud558\uba74 \ucf54\ub4dc \ubcc0\uacbd \uc0ac\ud56d\uc744 \uae30\ub85d\ud558\uace0, \uc774\uc804 \ubc84\uc804\uc73c\ub85c \ubcf5\uad6c\ud558\uba70, \ud300\uc6d0\ub4e4\uacfc \uc791\uc5c5\uc744 \uc6d0\ud65c\ud788 \uc9c4\ud589\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uc544\ub798\uc5d0\uc11c\ub294 Git\uc744 \ucc98\uc74c \uc2dc\uc791\ud558\ub294 \ucd08\ubcf4\uc790\ub3c4 \uc774\ud574\ud560 \uc218 \uc788\ub3c4\ub85d \ucc28\uadfc\ucc28\uadfc \uc124\uba85\ud558\uaca0\uc2b5\ub2c8\ub2e4.</p>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#1-git","title":"1. Git\uc758 \uae30\ubcf8 \uac1c\ub150 \uc774\ud574\ud558\uae30","text":"","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#11-git","title":"1.1 Git\uc774\ub780 \ubb34\uc5c7\uc778\uac00\uc694?","text":"<ul> <li>Git\uc740 \ubd84\uc0b0 \ubc84\uc804 \uad00\ub9ac \uc2dc\uc2a4\ud15c(DVCS)\uc785\ub2c8\ub2e4.</li> <li>\ud30c\uc77c\uc758 \ubcc0\uacbd \uae30\ub85d\uc744 \ucd94\uc801\ud558\uace0, \ud300\uc6d0\ub4e4\uacfc \ud30c\uc77c\uc744 \uacf5\uc720\ud560 \uc218 \uc788\uac8c \ud569\ub2c8\ub2e4.</li> <li>Git\uc744 \uc0ac\uc6a9\ud558\uba74 \ud2b9\uc815 \uc2dc\uc810\uc758 \uc0c1\ud0dc\ub85c \ubcf5\uad6c\ud558\uac70\ub098, \uc2e4\uc218\ub97c \ub418\ub3cc\ub9b4 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</li> </ul>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#12-git-github","title":"1.2 Git\uacfc GitHub\uc758 \ucc28\uc774","text":"<ul> <li>Git: \ub85c\uceec(\ub0b4 \ucef4\ud4e8\ud130)\uc5d0\uc11c \ubc84\uc804 \uad00\ub9ac\ub97c \uc218\ud589\ud558\ub294 \ub3c4\uad6c.</li> <li>GitHub: Git \uc800\uc7a5\uc18c\ub97c \uc628\ub77c\uc778\uc5d0\uc11c \ud638\uc2a4\ud305\ud558\uc5ec \ub2e4\ub978 \uc0ac\ub78c\uacfc \uacf5\uc720\ud560 \uc218 \uc788\ub294 \ud50c\ub7ab\ud3fc.</li> </ul>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#2-git","title":"2. Git \uc124\uce58 \ubc0f \ud658\uacbd \uc124\uc815","text":"","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#21-git","title":"2.1 Git \uc124\uce58","text":"<ul> <li>Windows: Git \uacf5\uc2dd \uc6f9\uc0ac\uc774\ud2b8\uc5d0\uc11c \uc124\uce58 \ud30c\uc77c \ub2e4\uc6b4\ub85c\ub4dc \ud6c4 \uc124\uce58.</li> <li>Mac: \ud130\ubbf8\ub110\uc5d0\uc11c <code>brew install git</code> \uba85\ub839\uc5b4 \uc2e4\ud589(\ud648\ube0c\ub8e8 \ud544\uc694).</li> <li>Linux: \uc544\ub798 \uba85\ub839\uc5b4 \uc2e4\ud589:     <code>bash     sudo apt-get install git</code></li> </ul>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#22-git","title":"2.2 Git \ucd08\uae30 \uc124\uc815","text":"<ol> <li>Git \uc0ac\uc6a9\uc790 \uc774\ub984\uacfc \uc774\uba54\uc77c \uc124\uc815:     <code>bash     git config --global user.name \"Your Name\"     git config --global user.email \"youremail@example.com\"</code></li> <li>\uc124\uc815 \ud655\uc778:     <code>bash     git config --list</code></li> </ol>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#3-git","title":"3. Git\uc758 \uae30\ubcf8 \uc791\uc5c5 \ud750\ub984 \uc774\ud574\ud558\uae30","text":"<p>Git\uc758 \uae30\ubcf8 \uc791\uc5c5 \ub2e8\uacc4\ub294 \ub2e4\uc74c\uacfc \uac19\uc2b5\ub2c8\ub2e4: 1. Working Directory(\uc791\uc5c5 \ub514\ub809\ud1a0\ub9ac): \uc2e4\uc81c \ud30c\uc77c\uc744 \ud3b8\uc9d1\ud558\ub294 \uacf5\uac04. 2. Staging Area(\uc2a4\ud14c\uc774\uc9d5 \uc601\uc5ed): \ucee4\ubc0b \uc804\uc5d0 \ubcc0\uacbd \uc0ac\ud56d\uc744 \uc900\ube44\ud558\ub294 \uacf5\uac04. 3. Repository(\uc800\uc7a5\uc18c): \ucee4\ubc0b\ub41c \ubcc0\uacbd \uc0ac\ud56d\uc774 \uc800\uc7a5\ub418\ub294 \uacf5\uac04.</p>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#4-git","title":"4. Git \uba85\ub839\uc5b4 \ubc30\uc6b0\uae30","text":"","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#41-git","title":"4.1 \uc0c8\ub85c\uc6b4 Git \uc800\uc7a5\uc18c \uc0dd\uc131","text":"<ol> <li>\uae30\uc874 \ub514\ub809\ud1a0\ub9ac\ub97c Git\uc73c\ub85c \ucd08\uae30\ud654:     <code>bash     git init</code></li> <li>\uc6d0\uaca9 \uc800\uc7a5\uc18c \uc5f0\uacb0:     <code>bash     git remote add origin https://github.com/yourusername/repository.git</code></li> </ol>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#42","title":"4.2 \ud30c\uc77c \uc0c1\ud0dc \ud655\uc778","text":"<ul> <li>\ubcc0\uacbd \uc0ac\ud56d \ud655\uc778:     <code>bash     git status</code></li> </ul>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#43","title":"4.3 \ud30c\uc77c \ucd94\uc801 \ubc0f \uc2a4\ud14c\uc774\uc9d5","text":"<ol> <li>\ud2b9\uc815 \ud30c\uc77c\uc744 \uc2a4\ud14c\uc774\uc9d5:     <code>bash     git add \ud30c\uc77c\uba85</code></li> <li>\ubaa8\ub4e0 \ud30c\uc77c\uc744 \uc2a4\ud14c\uc774\uc9d5:     <code>bash     git add .</code></li> </ol>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#44","title":"4.4 \ubcc0\uacbd \uc0ac\ud56d \uc800\uc7a5(\ucee4\ubc0b)","text":"<ul> <li>\uba54\uc2dc\uc9c0\ub97c \ud3ec\ud568\ud558\uc5ec \ubcc0\uacbd \uc0ac\ud56d \uc800\uc7a5:     <code>bash     git commit -m \"\ucee4\ubc0b \uba54\uc2dc\uc9c0\"</code></li> </ul>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#45","title":"4.5 \ubcc0\uacbd \uc0ac\ud56d \ud478\uc2dc(\uc5c5\ub85c\ub4dc)","text":"<ul> <li>\uc6d0\uaca9 \uc800\uc7a5\uc18c\uc5d0 \ud478\uc2dc:     <code>bash     git push origin main</code></li> </ul>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#5","title":"5. \uc2e4\uc218 \ubcf5\uad6c\ud558\uae30","text":"","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#51","title":"5.1 \ub9c8\uc9c0\ub9c9 \ucee4\ubc0b \uc218\uc815","text":"<ul> <li>\ucd5c\uadfc \ucee4\ubc0b \uba54\uc2dc\uc9c0\ub97c \ubcc0\uacbd:     <code>bash     git commit --amend -m \"\uc218\uc815\ub41c \uba54\uc2dc\uc9c0\"</code></li> </ul>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#52","title":"5.2 \uc2a4\ud14c\uc774\uc9d5 \ucde8\uc18c","text":"<ul> <li>\ud2b9\uc815 \ud30c\uc77c \uc2a4\ud14c\uc774\uc9d5 \ucde8\uc18c:     <code>bash     git reset \ud30c\uc77c\uba85</code></li> </ul>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#53","title":"5.3 \ubcc0\uacbd \uc0ac\ud56d \ub418\ub3cc\ub9ac\uae30","text":"<ul> <li>\ud2b9\uc815 \ud30c\uc77c\uc744 \ub9c8\uc9c0\ub9c9 \ucee4\ubc0b \uc0c1\ud0dc\ub85c \ubcf5\uad6c:     <code>bash     git checkout -- \ud30c\uc77c\uba85</code></li> </ul>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#6","title":"6. \ud611\uc5c5\ud558\uae30","text":"","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#61","title":"6.1 \uc6d0\uaca9 \uc800\uc7a5\uc18c \ubcf5\uc81c","text":"<ul> <li>GitHub\uc5d0\uc11c \uc800\uc7a5\uc18c\ub97c \ubcf5\uc81c:     <code>bash     git clone https://github.com/yourusername/repository.git</code></li> </ul>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#62","title":"6.2 \ube0c\ub79c\uce58 \uc0ac\uc6a9\ud558\uae30","text":"<ol> <li>\uc0c8 \ube0c\ub79c\uce58 \uc0dd\uc131 \ubc0f \uc774\ub3d9:     <code>bash     git checkout -b \ube0c\ub79c\uce58\uba85</code></li> <li>\ube0c\ub79c\uce58 \ubcd1\ud569:<ul> <li>\uba54\uc778 \ube0c\ub79c\uce58\ub85c \uc774\ub3d9 \ud6c4 \ubcd1\ud569:     <code>bash     git checkout main     git merge \ube0c\ub79c\uce58\uba85</code></li> </ul> </li> <li>\ube0c\ub79c\uce58 \uc0ad\uc81c:     <code>bash     git branch -d \ube0c\ub79c\uce58\uba85</code></li> </ol>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#7-github","title":"7. GitHub\uc640 \uc5f0\ub3d9\ud558\uae30","text":"","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#71-github","title":"7.1 GitHub\uc5d0 \uc800\uc7a5\uc18c \uc0dd\uc131","text":"<ol> <li>GitHub\uc5d0 \ub85c\uadf8\uc778 \ud6c4 \"New Repository\" \ud074\ub9ad.</li> <li>\uc800\uc7a5\uc18c \uc774\ub984 \uc785\ub825 \ud6c4 \"Create Repository\" \ud074\ub9ad.</li> </ol>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#72-github","title":"7.2 GitHub\uc5d0 \ucf54\ub4dc \ud478\uc2dc","text":"<ol> <li>GitHub\uc5d0\uc11c \uc81c\uacf5\ud558\ub294 URL \ubcf5\uc0ac.</li> <li>\ud130\ubbf8\ub110\uc5d0\uc11c \uc6d0\uaca9 \uc800\uc7a5\uc18c \uc124\uc815:     <code>bash     git remote add origin URL</code></li> <li>\ucf54\ub4dc \ud478\uc2dc:     <code>bash     git push -u origin main</code></li> </ol>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#8-git","title":"8. \uae30\ubcf8 Git \uc6cc\ud06c\ud50c\ub85c \uc5f0\uc2b5\ud558\uae30","text":"","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#1","title":"\uc5f0\uc2b5 1: \ud30c\uc77c \ucd94\uac00 \ud6c4 \ucee4\ubc0b","text":"<ol> <li>\uc0c8 \ud30c\uc77c \uc0dd\uc131:     <code>bash     echo \"Hello, Git!\" &gt; hello.txt</code></li> <li>\ud30c\uc77c \uc0c1\ud0dc \ud655\uc778:     <code>bash     git status</code></li> <li>\ud30c\uc77c \uc2a4\ud14c\uc774\uc9d5 \ubc0f \ucee4\ubc0b:     <code>bash     git add hello.txt     git commit -m \"Add hello.txt\"</code></li> </ol>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#2","title":"\uc5f0\uc2b5 2: \uc6d0\uaca9 \uc800\uc7a5\uc18c\uc640 \uc5f0\ub3d9","text":"<ol> <li>GitHub\uc5d0 \uc800\uc7a5\uc18c \uc0dd\uc131.</li> <li>\ub85c\uceec \uc800\uc7a5\uc18c\uc5d0 \uc5f0\uacb0:     <code>bash     git remote add origin URL</code></li> <li>\ud30c\uc77c \ud478\uc2dc:     <code>bash     git push origin main</code></li> </ol>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#9","title":"9. \ucd94\uac00 \ud559\uc2b5 \ub9ac\uc18c\uc2a4","text":"<ol> <li>Git \uacf5\uc2dd \ubb38\uc11c: https://git-scm.com/doc</li> <li>GitHub \uac00\uc774\ub4dc: https://guides.github.com</li> <li>\uc5f0\uc2b5 \ud50c\ub7ab\ud3fc: https://learngitbranching.js.org</li> </ol> <p>Git\uc740 \ucd08\ubcf4\uc790\uac00 \ucc98\uc74c \uc811\ud588\uc744 \ub54c \ubcf5\uc7a1\ud574 \ubcf4\uc77c \uc218 \uc788\uc9c0\ub9cc, \uc704 \ub2e8\uacc4\ub97c \ucc28\uadfc\ucc28\uadfc \ub530\ub77c\ud558\uba74 \uae08\ubc29 \uc775\uc219\ud574\uc9c8 \uc218 \uc788\uc2b5\ub2c8\ub2e4. \uafb8\uc900\ud788 \uc5f0\uc2b5\ud558\uba70 \uc790\uc2e0\ub9cc\uc758 \uc6cc\ud06c\ud50c\ub85c\ub97c \ub9cc\ub4e4\uc5b4 \ubcf4\uc138\uc694! \ud83d\ude0a  </p>","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%231/#git_1","title":"Git #\ubc84\uc804\uad00\ub9ac #\ucd08\ubcf4\uc790 #\ud611\uc5c5","text":"","tags":["Git","\ubc84\uc804\uad00\ub9ac","GitHub","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%232/","title":"\ub2f5\ubcc0\uacfc \ud559\uc2b5\uc744 \uc798\ud558\ub824\uba74","text":"<p>\uc9c4\uc9c0\ud558\uac8c \ubb3b\ub294 \ub9cc\ud07c \uc0c1\uc138\ud558\uace0 \uad6c\uccb4\uc801\uc73c\ub85c \uc124\uba85\ud558\ub294 \ub2a5\ub825\uc740 \ub2f5\ubcc0\uacfc \ud559\uc2b5\uc5d0\uc11c \ubaa8\ub450 \uc911\uc694\ud55c \uc694\uc18c\uc785\ub2c8\ub2e4. \uc544\ub798\uc5d0\uc11c\ub294 \uac01\uac01\uc5d0 \ub300\ud55c \ubc29\ubc95\uacfc \uc608\uc2dc\ub97c \ub4e4\uc5b4 \uc124\uba85\ud569\ub2c8\ub2e4.</p>","tags":["\ub2f5\ubcc0","\ud559\uc2b5","\ud6a8\uc728\uc801 \ubc29\ubc95","\uc131\uc7a5"]},{"location":"2024-12-21-%232/#1","title":"1. \ub2f5\ubcc0\ud558\ub294 \ubc29\ubc95","text":"","tags":["\ub2f5\ubcc0","\ud559\uc2b5","\ud6a8\uc728\uc801 \ubc29\ubc95","\uc131\uc7a5"]},{"location":"2024-12-21-%232/#11","title":"1.1 \uc9c8\ubb38\uc758 \ud575\uc2ec\uc744 \ud30c\uc545\ud558\uae30","text":"<ul> <li>\ud575\uc2ec \ud0a4\uc6cc\ub4dc\ub97c \ubf51\uc544 \uc9c8\ubb38\uc790\uac00 \ubb34\uc5c7\uc744 \uad81\uae08\ud574\ud558\ub294\uc9c0 \uc815\ud655\ud788 \uc774\ud574\ud558\uc138\uc694.</li> <li>\uc608\uc2dc 1: \"\uc5b4\ub5bb\uac8c \uc6b4\ub3d9\uc744 \uc798\ud560 \uc218 \uc788\ub098\uc694?\" \u2192 \ud575\uc2ec: \uc6b4\ub3d9, \uc798\ud558\ub294 \ubc29\ubc95 </li> <li>\uc608\uc2dc 2: \"\ud6a8\uc728\uc801\uc73c\ub85c \uc2dc\uac04 \uad00\ub9ac\ub97c \ud558\ub294 \ubc95\uc740?\" \u2192 \ud575\uc2ec: \uc2dc\uac04 \uad00\ub9ac, \ud6a8\uc728\uc131 </li> <li>\uc608\uc2dc 3: \"\ud504\ub85c\uadf8\ub798\ubc0d\uc744 \ucc98\uc74c \uc2dc\uc791\ud558\ub824\uba74 \uc5b4\ub5bb\uac8c \ud574\uc57c \ud558\ub098\uc694?\" \u2192 \ud575\uc2ec: \ud504\ub85c\uadf8\ub798\ubc0d, \uc2dc\uc791 \ubc29\ubc95 </li> </ul>","tags":["\ub2f5\ubcc0","\ud559\uc2b5","\ud6a8\uc728\uc801 \ubc29\ubc95","\uc131\uc7a5"]},{"location":"2024-12-21-%232/#12","title":"1.2 \uac04\ub2e8\ud558\uba74\uc11c\ub3c4 \uccb4\uacc4\uc801\uc73c\ub85c \ub300\ub2f5\ud558\uae30","text":"<ul> <li>\ubb38\uc81c\ub97c \ucabc\uac1c\uc5b4 \uc21c\uc11c\ub300\ub85c \uc124\uba85\ud558\uc138\uc694.</li> <li>\uc608\uc2dc 1: \uc6b4\ub3d9 \u2192 \"\ubaa9\ud45c\ub97c \uc815\ud558\uace0, \uc6b4\ub3d9 \uacc4\ud68d\uc744 \uc9dc\uace0, \uafb8\uc900\ud788 \uc2e4\ucc9c\ud574 \ubcf4\uc138\uc694.\"</li> <li>\uc608\uc2dc 2: \uc2dc\uac04 \uad00\ub9ac \u2192 \"1) \uc911\uc694\ud55c \uc77c\uc744 \uba3c\uc800 \uc815\ub9ac\ud558\uace0, 2) \ud560 \uc77c\uc744 \uc801\uace0, 3) \uc815\ud574\uc9c4 \uc2dc\uac04\uc5d0 \ub9de\ucdb0 \uc2e4\ucc9c\ud558\uc138\uc694.\"</li> <li>\uc608\uc2dc 3: \ud504\ub85c\uadf8\ub798\ubc0d \u2192 \"1) \ubc30\uc6b0\uace0 \uc2f6\uc740 \uc5b8\uc5b4\ub97c \uc815\ud558\uace0, 2) \uae30\ubcf8 \ubb38\ubc95\ubd80\ud130 \uc2dc\uc791\ud558\uace0, 3) \uc791\uc740 \ud504\ub85c\uc81d\ud2b8\ub97c \ud574\ubcf4\uc138\uc694.\"</li> </ul>","tags":["\ub2f5\ubcc0","\ud559\uc2b5","\ud6a8\uc728\uc801 \ubc29\ubc95","\uc131\uc7a5"]},{"location":"2024-12-21-%232/#13","title":"1.3 \uc9c8\ubb38\uc790\uc758 \uc0c1\ud669\uc744 \uace0\ub824\ud558\uae30","text":"<ul> <li>\uc9c8\ubb38\uc790\uc758 \ubc30\uacbd \uc9c0\uc2dd, \uacbd\ud5d8, \uad00\uc2ec\uc0ac\uc5d0 \ub9de\ucd98 \ub300\ub2f5\uc774 \ub354 \ud6a8\uacfc\uc801\uc785\ub2c8\ub2e4.</li> <li>\uc608\uc2dc 1: \uc6b4\ub3d9 \u2192 \ucd08\ubcf4\uc790\ub77c\uba74 \uae30\ucd08\ubd80\ud130, \uacbd\ud5d8\uc790\ub77c\uba74 \uc2ec\ud654 \ubc29\ubc95 \ucd94\ucc9c.  </li> <li>\uc608\uc2dc 2: \uc2dc\uac04 \uad00\ub9ac \u2192 \ubc14\uc05c \uc9c1\uc7a5\uc778\uc5d0\uac90 \uac04\ub2e8\ud55c \uc571 \ucd94\ucc9c, \uc5ec\uc720 \uc788\ub294 \uc0ac\ub78c\uc5d0\uac90 \uc885\uc774 \ub2e4\uc774\uc5b4\ub9ac \ucd94\ucc9c.  </li> <li>\uc608\uc2dc 3: \ud504\ub85c\uadf8\ub798\ubc0d \u2192 \ucd08\ubcf4\uc790\uc5d0\uac8c\ub294 \"\uc26c\uc6b4 \uc5b8\uc5b4 \uba3c\uc800\", \uacbd\ud5d8\uc790\uc5d0\uac8c\ub294 \"\ub3c4\uc804 \uacfc\uc81c\" \uc81c\uc548.  </li> </ul>","tags":["\ub2f5\ubcc0","\ud559\uc2b5","\ud6a8\uc728\uc801 \ubc29\ubc95","\uc131\uc7a5"]},{"location":"2024-12-21-%232/#2","title":"2. \ud559\uc2b5\ud558\ub294 \ubc29\ubc95","text":"","tags":["\ub2f5\ubcc0","\ud559\uc2b5","\ud6a8\uc728\uc801 \ubc29\ubc95","\uc131\uc7a5"]},{"location":"2024-12-21-%232/#21","title":"2.1 \ubaa9\ud45c\ub97c \uc138\uc6b0\uace0 \uad6c\uccb4\uc801\uc73c\ub85c \ub098\ub204\uae30","text":"<ul> <li>\ud559\uc2b5\ud558\ub824\ub294 \ub0b4\uc6a9\uc744 \uc791\uc740 \ub2e8\uacc4\ub85c \ub098\ub204\uace0, \ud558\ub098\uc529 \ud574\uacb0\ud558\uc138\uc694.</li> <li>\uc608\uc2dc 1: \uc6b4\ub3d9 \ubc30\uc6b0\uae30 \u2192  <ul> <li>1\uc8fc \ucc28: \uc2a4\ud2b8\ub808\uce6d \ubc30\uc6b0\uae30.  </li> <li>2\uc8fc \ucc28: \uac77\uae30\uc640 \ub2ec\ub9ac\uae30 \uc2e4\ucc9c.  </li> <li>3\uc8fc \ucc28: \uadfc\ub825 \uc6b4\ub3d9 \ucd94\uac00.  </li> </ul> </li> <li>\uc608\uc2dc 2: \uc2dc\uac04 \uad00\ub9ac \u2192  <ul> <li>\uccab\ub0a0: \ud558\ub8e8 \uacc4\ud68d \uc138\uc6b0\uae30.  </li> <li>\ub458\uc9f8 \ub0a0: \uc6b0\uc120\uc21c\uc704 \uc815\ub9ac\ubc95 \ubc30\uc6b0\uae30.  </li> <li>\uc14b\uc9f8 \ub0a0: \uc2e4\ucc9c\ud55c \ub4a4 \uae30\ub85d \ub0a8\uae30\uae30.  </li> </ul> </li> <li>\uc608\uc2dc 3: \ud504\ub85c\uadf8\ub798\ubc0d \u2192  <ul> <li>\uccab \uc8fc: \ubb38\ubc95 \uc774\ud574.  </li> <li>\ub458\uc9f8 \uc8fc: \ucf54\ub4dc \ub530\ub77c \uc368\ubcf4\uae30.  </li> <li>\uc14b\uc9f8 \uc8fc: \uac04\ub2e8\ud55c \ud504\ub85c\uadf8\ub7a8 \ub9cc\ub4e4\uc5b4\ubcf4\uae30.  </li> </ul> </li> </ul>","tags":["\ub2f5\ubcc0","\ud559\uc2b5","\ud6a8\uc728\uc801 \ubc29\ubc95","\uc131\uc7a5"]},{"location":"2024-12-21-%232/#22","title":"2.2 \uc790\ub8cc\ub97c \ucc3e\uace0 \ud65c\uc6a9\ud558\uae30","text":"<ul> <li>\uc88b\uc740 \uc790\ub8cc\ub97c \ucc3e\uc544 \ubc30\uc6b0\uace0 \ub530\ub77c \ud558\uc138\uc694.</li> <li>\uc608\uc2dc 1: \uc6b4\ub3d9 \u2192 \uc720\ud29c\ube0c \uc6b4\ub3d9 \uac15\uc758, \ud5ec\uc2a4\uc7a5 \ucf54\uce58\uc758 \ub3c4\uc6c0.  </li> <li>\uc608\uc2dc 2: \uc2dc\uac04 \uad00\ub9ac \u2192 \uc0dd\uc0b0\uc131 \ub3c4\uc11c(\uc608: \uc544\uce68 5\uc2dc\uc758 \uae30\uc801), \ud50c\ub798\ub108 \uc0ac\uc6a9\ubc95 \uac15\uc758.  </li> <li>\uc608\uc2dc 3: \ud504\ub85c\uadf8\ub798\ubc0d \u2192 \ubb34\ub8cc \uac15\uc758 \ud50c\ub7ab\ud3fc(\ucf54\ub4dc \uc544\uce74\ub370\ubbf8, \uc720\ub370\ubbf8), \uc785\ubb38\uc11c.  </li> </ul>","tags":["\ub2f5\ubcc0","\ud559\uc2b5","\ud6a8\uc728\uc801 \ubc29\ubc95","\uc131\uc7a5"]},{"location":"2024-12-21-%232/#23","title":"2.3 \ubc18\ubcf5\ud558\uba70 \uc2e4\ucc9c\ud558\uae30","text":"<ul> <li>\ud559\uc2b5 \ub0b4\uc6a9\uc744 \uafb8\uc900\ud788 \ubc18\ubcf5\ud558\uba70 \uc2e4\ucc9c\ud558\uba74 \uc774\ud574\uac00 \uae4a\uc5b4\uc9c0\uace0 \uae30\uc5b5\uc774 \uc624\ub798\uac11\ub2c8\ub2e4.</li> <li>\uc608\uc2dc 1: \uc6b4\ub3d9 \u2192 \ub9e4\uc77c \uc870\uae08\uc529 \ub298\ub9ac\uae30(\ucc98\uc74c\uc5d4 10\ubd84, \ub098\uc911\uc5d4 30\ubd84).  </li> <li>\uc608\uc2dc 2: \uc2dc\uac04 \uad00\ub9ac \u2192 \ub9e4\uc77c \uc800\ub141 \uacc4\ud68d \uc810\uac80 \ubc0f \uc218\uc815.  </li> <li>\uc608\uc2dc 3: \ud504\ub85c\uadf8\ub798\ubc0d \u2192 \ub9e4\uc8fc \uc791\uc740 \ud504\ub85c\uc81d\ud2b8 \uc644\uc131.  </li> </ul>","tags":["\ub2f5\ubcc0","\ud559\uc2b5","\ud6a8\uc728\uc801 \ubc29\ubc95","\uc131\uc7a5"]},{"location":"2024-12-21-%232/#_2","title":"\uacb0\ub860: \ub2f5\ubcc0\uacfc \ud559\uc2b5\uc744 \uc798\ud558\ub824\uba74","text":"<ol> <li>\ub2f5\ubcc0\ud560 \ub54c\ub294 \uc9c8\ubb38\uc758 \ud575\uc2ec\uc744 \ud30c\uc545\ud558\uace0 \uccb4\uacc4\uc801\uc73c\ub85c \ub300\ub2f5\ud558\uba70 \uc9c8\ubb38\uc790\uc758 \uc0c1\ud669\uc744 \uace0\ub824\ud558\uc138\uc694.  </li> <li>\ud559\uc2b5\ud560 \ub54c\ub294 \ubaa9\ud45c\ub97c \ub098\ub204\uace0, \uc790\ub8cc\ub97c \ud65c\uc6a9\ud558\uba70, \ubc18\ubcf5 \uc2e4\ucc9c\ud558\ub294 \uc2b5\uad00\uc744 \uae30\ub974\uc138\uc694.  </li> </ol> <p>\uc774 \uacfc\uc815\uc744 \uafb8\uc900\ud788 \uc5f0\uc2b5\ud558\uba74 \ub204\uad6c\ub098 \ub354 \ub098\uc740 \ub2f5\ubcc0\uacfc \ud559\uc2b5\uc744 \ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4! \ud83c\udf1f  </p>","tags":["\ub2f5\ubcc0","\ud559\uc2b5","\ud6a8\uc728\uc801 \ubc29\ubc95","\uc131\uc7a5"]},{"location":"2024-12-21-%232/#_3","title":"\ub2f5\ubcc0\uc2a4\ud0ac #\ud6a8\uc728\uc801\ud559\uc2b5 #\uc131\uc7a5\ud558\uae30","text":"","tags":["\ub2f5\ubcc0","\ud559\uc2b5","\ud6a8\uc728\uc801 \ubc29\ubc95","\uc131\uc7a5"]},{"location":"2024-12-21-%233/","title":"\ud64d\ucc28\uc640 \uc5bc\uadf8\ub808\uc774\uc758 \uc2ec\uce35 \ubd84\uc11d","text":"","tags":["\ud64d\ucc28","\uc5bc\uadf8\ub808\uc774","\ub2e4\ub974\uc9c8\ub9c1","\ubb38\ud654","\uac74\uac15"]},{"location":"2024-12-21-%233/#_1","title":"\uc694\uc57d","text":"<p>\ud64d\ucc28\uc640 \uc5bc\uadf8\ub808\uc774\ub97c \uc911\uc2ec\uc73c\ub85c \ub2e4\uc591\ud55c \uad00\uc810\uc5d0\uc11c \ubd84\uc11d\ud55c \uacb0\uacfc\ubb3c\uc785\ub2c8\ub2e4. \ud64d\ucc28\uc758 \uc5ed\uc0ac, \uac74\uac15\uc801 \uc774\uc810, \uc2ec\ub9ac\uc801 \uc548\uc815 \ud6a8\uacfc, \uadf8\ub9ac\uace0 \uc2a4\ubab0\ud1a0\ud06c\uc5d0\uc11c\uc758 \ud65c\uc6a9 \uac00\ub2a5\uc131 \ub4f1\uc744 \uccb4\uacc4\uc801\uc73c\ub85c \uc815\ub9ac\ud588\uc2b5\ub2c8\ub2e4. \ucca0\ud559\uc801 \ub300\ud654 \uc139\uc158\uc744 \ud3ec\ud568\ud558\uc5ec, \ucc28\ub97c \ud1b5\ud574 \uc5bb\uc744 \uc218 \uc788\ub294 \ub0b4\uba74\uc801 \ud1b5\ucc30\uacfc \uc815\uc11c\uc801 \uc704\uc548\uc744 \uac15\uc870\ud558\uc600\uc2b5\ub2c8\ub2e4.</p>","tags":["\ud64d\ucc28","\uc5bc\uadf8\ub808\uc774","\ub2e4\ub974\uc9c8\ub9c1","\ubb38\ud654","\uac74\uac15"]},{"location":"2024-12-21-%233/#1","title":"1. \ud64d\ucc28 \uc804\ubb38\uac00\uc758 \uad00\uc810","text":"<ul> <li>\ub2e4\ub974\uc9c8\ub9c1: \uc12c\uc138\ud55c \uaf43\ud5a5\uae30\uc640 \uba38\uc2a4\ucea3 \ud3ec\ub3c4\ud5a5\uc774 \ud2b9\uc9d5\uc73c\ub85c, \uc2a4\ud2b8\ub808\uc774\ud2b8 \ud2f0\ub85c \uc990\uae30\uae30 \uc801\ud569.</li> <li>\uc5bc\uadf8\ub808\uc774: \ubca0\ub974\uac00\ubabb \uc624\uc77c\uc758 \uc0c1\ucf8c\ud55c \uac10\uade4 \ud5a5\uc774 \uc778\uc0c1\uc801\uc774\uba70, \uc560\ud504\ud130\ub208 \ud2f0\uc758 \ub300\ud45c\uc8fc\uc790.</li> </ul>","tags":["\ud64d\ucc28","\uc5bc\uadf8\ub808\uc774","\ub2e4\ub974\uc9c8\ub9c1","\ubb38\ud654","\uac74\uac15"]},{"location":"2024-12-21-%233/#2","title":"2. \uc2ec\ub9ac\ud559\uc801 \uad00\uc810","text":"<ul> <li>\uc815\uc11c\uc801 \uc548\uc815: \uc5bc\uadf8\ub808\uc774\uc758 \uac10\uade4 \ud5a5\uc740 \uc2a4\ud2b8\ub808\uc2a4 \uc644\ud654\uc5d0, \ub2e4\ub974\uc9c8\ub9c1\uc740 \uc9d1\uc911\ub825 \ud5a5\uc0c1\uc5d0 \uae30\uc5ec.</li> <li>\uba85\uc0c1 \ud6a8\uacfc: \ucc28\ub97c \ub9c8\uc2dc\ub294 \uacfc\uc815\uc774 \ub0b4\uba74\uc801 \uace0\uc694\ub97c \uc720\ub3c4.</li> </ul>","tags":["\ud64d\ucc28","\uc5bc\uadf8\ub808\uc774","\ub2e4\ub974\uc9c8\ub9c1","\ubb38\ud654","\uac74\uac15"]},{"location":"2024-12-21-%233/#3","title":"3. \uac74\uac15 \uc804\ubb38\uac00\uc758 \ud1b5\ucc30","text":"<ul> <li>\ud56d\uc0b0\ud654 \ud6a8\uacfc: \uba74\uc5ed\ub825 \uac15\ud654\uc640 \ub178\ud654 \ubc29\uc9c0\uc5d0 \ub3c4\uc6c0.</li> <li>\uce74\ud398\uc778 \uc7a5\uc810: \uc801\ub2f9\ud55c \uce74\ud398\uc778 \uc12d\ucde8\ub85c \ud53c\ub85c \ud68c\ubcf5 \ubc0f \uc5d0\ub108\uc9c0 \ubd80\uc2a4\ud305.</li> <li>\ucca8\uac00\ubb3c \uc5ec\ubd80: \ub2e4\ub974\uc9c8\ub9c1\uc740 \uc2a4\ud2b8\ub808\uc774\ud2b8\ub85c \ub9c8\uc2dc\ub294 \uac83\uc774 \uac74\uac15\uc0c1\uc758 \uc774\uc810 \uadf9\ub300\ud654.</li> </ul>","tags":["\ud64d\ucc28","\uc5bc\uadf8\ub808\uc774","\ub2e4\ub974\uc9c8\ub9c1","\ubb38\ud654","\uac74\uac15"]},{"location":"2024-12-21-%233/#4","title":"4. \ubb38\ud654 \uc5f0\uad6c\uc790\uc758 \ud574\uc11d","text":"<ul> <li>\uc5ed\uc0ac\uc801 \ub9e5\ub77d:</li> <li>\ub2e4\ub974\uc9c8\ub9c1: \uc2dd\ubbfc\uc9c0 \uc2dc\ub300\uc640 \uc5f0\uad00\ub41c \uc815\uce58\uc801, \ubb38\ud654\uc801 \uc758\ubbf8.</li> <li>\uc5bc\uadf8\ub808\uc774: \uc720\ub7fd \uadc0\uc871 \ubb38\ud654\uc640 \uc560\ud504\ud130\ub208 \ud2f0 \uc804\ud1b5\uc758 \uc0c1\uc9d5.</li> <li>\uc2a4\ubab0\ud1a0\ud06c \uc18c\uc7ac: \uac01 \ucc28\uc758 \ubb38\ud654\uc801 \ubc30\uacbd\uc740 \ub300\ud654\ub97c \ud48d\ubd80\ud558\uac8c \ub9cc\ub4e4\uc5b4\uc90c.</li> </ul>","tags":["\ud64d\ucc28","\uc5bc\uadf8\ub808\uc774","\ub2e4\ub974\uc9c8\ub9c1","\ubb38\ud654","\uac74\uac15"]},{"location":"2024-12-21-%233/#5-hermit","title":"5. \ucca0\ud559\uc790(HERMIT)\uc758 \uc0ac\uc0c9","text":"<ul> <li>\ucc28\uc758 \uc0c1\uc9d5\uc131:</li> <li>\uc5bc\uadf8\ub808\uc774: \uc21c\uac04\uc758 \ud65c\ub825\uc744 \uc0c1\uc9d5.</li> <li>\ub2e4\ub974\uc9c8\ub9c1: \ub0b4\uba74\uc801 \uace0\uc694\uc640 \uc5f0\uacb0.</li> <li>\uc0b6\uc758 \ubcf5\uc7a1\uc131\uacfc \uc0ac\uc0c9: \ucc28\ub97c \ub9c8\uc2dc\ub294 \ud589\uc704\ub294 \uc874\uc7ac\uc758 \ub2e4\uc591\uc131\uc744 \ud0d0\uad6c\ud558\ub294 \uc77c\ud658.</li> </ul>","tags":["\ud64d\ucc28","\uc5bc\uadf8\ub808\uc774","\ub2e4\ub974\uc9c8\ub9c1","\ubb38\ud654","\uac74\uac15"]},{"location":"2024-12-21-%233/#6","title":"6. \uc0ac\uc6a9\uc790\uc758 \ub9c8\uc74c\uc744 \uc5b4\ub8e8\ub9cc\uc9c0\ub294 \ub300\ud654","text":"","tags":["\ud64d\ucc28","\uc5bc\uadf8\ub808\uc774","\ub2e4\ub974\uc9c8\ub9c1","\ubb38\ud654","\uac74\uac15"]},{"location":"2024-12-21-%233/#_2","title":"\ucc28\uc640 \uc815\uc11c\uc801 \uc704\uc548","text":"<ul> <li>\uc804\ubb38\uac00 \uc870\uc5b8:</li> <li>\"\uc5bc\uadf8\ub808\uc774\ub294 \ud65c\ub825\uc744, \ub2e4\ub974\uc9c8\ub9c1\uc740 \ud3c9\uc628\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4.\"</li> <li>\"\ucc28\ub97c \ub9c8\uc2dc\ub294 \uc21c\uac04\uc740 \uc2a4\uc2a4\ub85c\ub97c \uc704\ud55c \uc2dc\uac04\uc774 \ub418\uae30\ub97c \ubc14\ub78d\ub2c8\ub2e4.\"</li> </ul>","tags":["\ud64d\ucc28","\uc5bc\uadf8\ub808\uc774","\ub2e4\ub974\uc9c8\ub9c1","\ubb38\ud654","\uac74\uac15"]},{"location":"2024-12-21-%233/#_3","title":"\ucc28\uc640 \ud558\ub8e8\uc758 \ub9ac\ub4ec","text":"<ul> <li>\uc544\uce68: \uac15\ub82c\ud55c \uc544\uc0bc</li> <li>\uc624\ud6c4: \uc12c\uc138\ud55c \ub2e4\ub974\uc9c8\ub9c1</li> <li>\uc800\ub141: \ub514\uce74\ud398\uc778 \ucc28</li> </ul>","tags":["\ud64d\ucc28","\uc5bc\uadf8\ub808\uc774","\ub2e4\ub974\uc9c8\ub9c1","\ubb38\ud654","\uac74\uac15"]},{"location":"2024-12-21-%233/#_4","title":"\uc2a4\ubab0\ud1a0\ud06c\ub85c \uc0ac\ud68c\uc801 \uc5f0\uacb0 \uac15\ud654","text":"<ul> <li>\uc5bc\uadf8\ub808\uc774\uc640 \uc601\uad6d \uc804\ud1b5</li> <li>\ub2e4\ub974\uc9c8\ub9c1\uacfc \uc138\uacc4\uc0ac\uc801 \ub9e5\ub77d</li> </ul>","tags":["\ud64d\ucc28","\uc5bc\uadf8\ub808\uc774","\ub2e4\ub974\uc9c8\ub9c1","\ubb38\ud654","\uac74\uac15"]},{"location":"2024-12-21-%233/#hermit","title":"\ucca0\ud559\uc801 \ub300\ud654: HERMIT\uc640\uc758 \ub300\ud654","text":"<ul> <li>HERMIT: \"\ucc28\ub97c \ub9c8\uc2dc\ub294 \uc774\uc720\ub294 \ubb34\uc5c7\uc785\ub2c8\uae4c?\"</li> <li>\uc0ac\uc6a9\uc790: \"\uc81c \uc790\uc2e0\uc744 \ub3cc\uc544\ubcf4\ub294 \uc2dc\uac04\uc785\ub2c8\ub2e4.\"</li> <li>HERMIT: \"\ucc28\ub294 \ub2e8\uc21c\ud55c \uc74c\ub8cc\ub97c \ub118\uc5b4 \uc0b6\uc758 \ubcf5\uc7a1\uc131\uacfc \uc544\ub984\ub2e4\uc6c0\uc744 \uc774\ud574\ud558\ub294 \ub3c4\uad6c\uc785\ub2c8\ub2e4.\"</li> </ul>","tags":["\ud64d\ucc28","\uc5bc\uadf8\ub808\uc774","\ub2e4\ub974\uc9c8\ub9c1","\ubb38\ud654","\uac74\uac15"]},{"location":"2024-12-21-%233/#_5","title":"\uacb0\ub860","text":"<p>\ud64d\ucc28\uc640 \uc5bc\uadf8\ub808\uc774\ub294 \uc77c\uc0c1\uacfc \ub0b4\uba74\uc744 \uc5f0\uacb0\ud558\ub294 \ub9e4\uac1c\uccb4\ub85c, \uc0b6\uc758 \uc5ec\uc720\uc640 \ud1b5\ucc30\uc744 \uc81c\uacf5\ud569\ub2c8\ub2e4. \ucc28 \ud55c \uc794\uacfc \ud568\uaed8 \uc624\ub298 \uc2a4\uc2a4\ub85c\ub97c \uc704\ud55c \uc2dc\uac04\uc744 \uac00\uc838\ubcf4\uc138\uc694! \u2615</p>","tags":["\ud64d\ucc28","\uc5bc\uadf8\ub808\uc774","\ub2e4\ub974\uc9c8\ub9c1","\ubb38\ud654","\uac74\uac15"]},{"location":"2024-12-21-%233/#_6","title":"\ud64d\ucc28 #\uc5bc\uadf8\ub808\uc774 #\ub2e4\ub974\uc9c8\ub9c1 #\ub0b4\uc801\ud3c9\uc628 #\ucca0\ud559\uc801\ud1b5\ucc30","text":"","tags":["\ud64d\ucc28","\uc5bc\uadf8\ub808\uc774","\ub2e4\ub974\uc9c8\ub9c1","\ubb38\ud654","\uac74\uac15"]},{"location":"2024-12-21-%234/","title":"GitHub Actions\uc640 MkDocs\ub97c \uc774\uc6a9\ud55c \uc790\ub3d9 \ubc30\ud3ec \uac00\uc774\ub4dc","text":"<p>\uc544\ub798\ub294 GitHub Actions\ub97c \uc0ac\uc6a9\ud574 MkDocs \uc0ac\uc774\ud2b8\ub97c \uc790\ub3d9 \ube4c\ub4dc \ubc0f \ubc30\ud3ec(gh-deploy) \ud558\ub294 \ubc29\ubc95\uc5d0 \ub300\ud55c, \uc644\uc804 \ucd08\ubcf4\uc790\uc6a9 \uac00\uc774\ub4dc\uc785\ub2c8\ub2e4.</p> <p>\uc774 \uac00\uc774\ub4dc\ub294 \uc774\ubbf8 \ub2e4\uc74c\uacfc \uac19\uc740 \uc0c1\ud0dc\ub97c \uac00\uc815\ud569\ub2c8\ub2e4:</p> <ol> <li>\ud504\ub85c\uc81d\ud2b8 \uad6c\uc870</li> </ol> <p>requirements.txt, app.py (Streamlit \ucf54\ub4dc), mkdocs.yml(\ub610\ub294 \uc0dd\uc131 \uc608\uc815), docs/ \ud3f4\ub354 \ub4f1\uc774 \ud3ec\ud568\ub41c \ub808\ud3ec\uc9c0\ud1a0\ub9ac</p> <p>app.py\uc5d0\ub294 \ud504\ub85c\uc81d\ud2b8\uc5d0\uc11c \uc0ac\uc6a9 \uc911\uc778 mkdocs \ube4c\ub4dc \ub85c\uc9c1\uc774 \ud3ec\ud568\ub428(\uc2e4\uc81c\ub85c \ube4c\ub4dc/\ubc30\ud3ec\ub294 \ub85c\uceec\uc774\ub098 GitHub Actions\uc5d0\uc11c \uc2e4\ud589)</p> <ol> <li>GitHub \ub9ac\ud3ec\uc9c0\ud1a0\ub9ac</li> </ol> <p>\uc774 \ud504\ub85c\uc81d\ud2b8\uac00 \ud638\uc2a4\ud305\ub420 GitHub \uc800\uc7a5\uc18c\uac00 \uc788\uc2b5\ub2c8\ub2e4(\uc608: https://github.com/&lt;\uc0ac\uc6a9\uc790\uba85&gt;/&lt;\ub808\ud3ec\uba85&gt;.git).</p> <p>\ub85c\uceec PC\uc5d0\uc11c Git\uc73c\ub85c \uad00\ub9ac \uc911\uc774\uac70\ub098, GitHub Codespaces/VSC\ub97c \uc0ac\uc6a9\ud574 \uad00\ub9ac \uc911</p> <ol> <li>main \ube0c\ub79c\uce58</li> </ol> <p>GitHub\uc5d0\uc11c \uae30\ubcf8 \ube0c\ub79c\uce58\ub97c main\uc73c\ub85c \uc0ac\uc6a9\ud55c\ub2e4\uace0 \uac00\uc815(\ub9cc\uc57d master\uac00 \uae30\ubcf8\uc774\ub77c\uba74 \uc544\ub798 \ubaa8\ub4e0 main\uc744 master\ub85c \ubc14\uafd4\uc8fc\uc138\uc694).</p> <ol> <li>GitHub Pages\ub97c \ud65c\uc6a9\ud55c MkDocs \ud638\uc2a4\ud305 \uac1c\ub150</li> </ol> <p>MkDocs: Markdown \ubb38\uc11c\ub97c \uc815\uc801 \uc0ac\uc774\ud2b8 \ud615\ud0dc\ub85c \ube4c\ub4dc\ud574\uc8fc\ub294 \ud234</p> <p>GitHub Pages: GitHub\uc5d0\uc11c \uc81c\uacf5\ud558\ub294 \uc815\uc801 \ud638\uc2a4\ud305(HTML/CSS/JS \ud30c\uc77c \ub4f1\uc744 \ubc30\ud3ec \uac00\ub2a5)</p> <p>mkdocs gh-deploy: MkDocs\uac00 \ub85c\uceec Git \ub9ac\ud3ec\uc9c0\ud1a0\ub9ac\uc5d0\uc11c gh-pages \ube0c\ub79c\uce58\ub85c \uc815\uc801 \ud30c\uc77c\uc744 \ud478\uc2dc\ud574\uc8fc\ub294 \uba85\ub839\uc5b4</p> <p>\ubb38\uc81c\ub294, Streamlit Cloud \ud658\uacbd\uc5d0\uc11c\ub294 .git \ud3f4\ub354\ub098 \uc6d0\uaca9 \uc800\uc7a5\uc18c \uc124\uc815(origin)\uc774 \uc5c6\uc5b4\uc11c mkdocs gh-deploy\uac00 \uc2e4\ud328\ud569\ub2c8\ub2e4. \uc774\ub97c GitHub Actions\uac00 \ub300\uc2e0 \ud574\uc8fc\uba74, main \ube0c\ub79c\uce58\uc5d0 \ubcc0\uacbd\uc774 \ub4e4\uc5b4\uc62c \ub54c\ub9c8\ub2e4 \uc790\ub3d9\uc73c\ub85c MkDocs\ub97c \ube4c\ub4dc\ud558\uace0 gh-pages\ub85c \ubc30\ud3ec\ud574\uc8fc\ubbc0\ub85c \ud3b8\ub9ac\ud569\ub2c8\ub2e4.</p> <ol> <li>GitHub Actions \uc124\uc815 \uac1c\uc694</li> </ol> <p>GitHub Actions\ub294 GitHub \ub808\ud3ec\uc9c0\ud1a0\ub9ac \uc548\uc5d0 .github/workflows \ud3f4\ub354\ub97c \ub9cc\ub4e4\uc5b4\uc11c, \uadf8 \uc548\uc5d0 YAML \ud30c\uc77c\uc744 \uc791\uc131\ud558\uba74 \ub3d9\uc791\ud569\ub2c8\ub2e4. \uc774 YAML \ud30c\uc77c\uc744 \u201c\uc6cc\ud06c\ud50c\ub85c\uc6b0\u201d\ub77c\uace0 \ubd80\ub974\uba70, main \ube0c\ub79c\uce58\ub85c push\uac00 \ubc1c\uc0dd\ud560 \ub54c\ub9c8\ub2e4 \uc790\ub3d9\uc73c\ub85c \uc2e4\ud589\ub429\ub2c8\ub2e4.</p> <p>2.1 \ud3f4\ub354 &amp; \ud30c\uc77c \uad6c\uc870 \uc608\uc2dc</p> <p>my-git-journal/  \u251c\u2500 .github/  \u2502   \u2514\u2500 workflows/  \u2502       \u2514\u2500 mkdocs-deploy.yml   &lt;-- \uc5ec\uae30\uc11c \uc790\ub3d9 \ubc30\ud3ec \uc124\uc815  \u251c\u2500 docs/  \u2502   \u2514\u2500 index.md  \u251c\u2500 mkdocs.yml  \u251c\u2500 app.py  \u251c\u2500 requirements.txt  \u2514\u2500 ...</p> <ol> <li> <p>GitHub Actions \uc6cc\ud06c\ud50c\ub85c\uc6b0 \ud30c\uc77c \uc791\uc131 (mkdocs-deploy.yml)</p> </li> <li> <p>\ud504\ub85c\uc81d\ud2b8 \ub8e8\ud2b8 \ub514\ub809\ud130\ub9ac\uc5d0 .github/workflows \ud3f4\ub354 \uc0dd\uc131(\uc5c6\uc73c\uba74 \uc0c8\ub85c \ub9cc\ub4e6)</p> </li> <li> <p>\uadf8 \uc548\uc5d0 mkdocs-deploy.yml \ub77c\ub294 \uc774\ub984\uc73c\ub85c \ud30c\uc77c \uc791\uc131</p> </li> <li> <p>\ub0b4\uc6a9 \uc608\uc2dc:</p> </li> </ol> <p>name: Deploy MkDocs to GitHub Pages</p> <p>on:   push:     branches: [ \"main\" ]   # main \ube0c\ub79c\uce58\uc5d0 push\ub420 \ub54c \ub3d9\uc791</p> <p>jobs:   build-deploy:     runs-on: ubuntu-latest     steps:       # (1) \uc18c\uc2a4\ucf54\ub4dc \uac00\uc838\uc624\uae30       - name: Check out the repository         uses: actions/checkout@v3</p> <pre><code>  # (2) Python \uc124\uce58 (3.9 \ubc84\uc804 \uc608\uc2dc)\n  - name: Set up Python\n    uses: actions/setup-python@v2\n    with:\n      python-version: \"3.9\"\n\n  # (3) \uc758\uc874\uc131 \uc124\uce58\n  - name: Install dependencies\n    run: |\n      pip install --upgrade pip\n      pip install -r requirements.txt\n      # requirements.txt\uc5d0 mkdocs, mkdocs-material, streamlit \ub4f1 \uc774\ubbf8 \uc791\uc131\ub428\n\n  # (4) mkdocs build &amp; gh-deploy\n  - name: Build and deploy to GitHub Pages\n    run: |\n      mkdocs build\n      mkdocs gh-deploy --force\n</code></pre> <p>\uc704 \uc2a4\ud06c\ub9bd\ud2b8\uac00 \ud558\ub294 \uc77c\uc740:</p> <ol> <li> <p>main \ube0c\ub79c\uce58\ub85c push\ub420 \ub54c \uc790\ub3d9 \ud2b8\ub9ac\uac70</p> </li> <li> <p>Ubuntu \ud658\uacbd\uc5d0\uc11c Python 3.9 \uc124\uce58</p> </li> <li> <p>pip install -r requirements.txt (\uc5ec\uae30\uc5d0 mkdocs, mkdocs-material, \ub4f1\ub4f1\uc774 \ub4e4\uc5b4\uc788\uc5b4\uc57c \ud568)</p> </li> <li> <p>mkdocs build \u2192 mkdocs gh-deploy --force</p> </li> </ol> <ol> <li> <p>main \ube0c\ub79c\uce58\ub85c \ucee4\ubc0b &amp; \ud478\uc2dc \u2192 GitHub Actions \ub3d9\uc791</p> </li> <li> <p>\ub85c\uceec\uc5d0\uc11c .github/workflows/mkdocs-deploy.yml \ud30c\uc77c \uc0dd\uc131/\uc218\uc815 \ud6c4 git add . &amp;&amp; git commit -m \"Add mkdocs actions\"</p> </li> <li> <p>git push origin main</p> </li> <li> <p>GitHub\uc5d0 \uac00\uc11c Actions \ud0ed\uc744 \ubcf4\uba74, \u201cDeploy MkDocs to GitHub Pages\u201d \uc6cc\ud06c\ud50c\ub85c\uc6b0\uac00 \uc2e4\ud589\ub418\ub294 \uac83\uc744 \ud655\uc778 \uac00\ub2a5</p> </li> <li> <p>\ube4c\ub4dc\uac00 \uc131\uacf5\ud558\uba74, gh-pages \ube0c\ub79c\uce58\uac00 \uc790\ub3d9 \uc0dd\uc131\ub418\uc5b4 \uc815\uc801 \ud30c\uc77c\ub4e4\uc774 \uc62c\ub77c\uac11\ub2c8\ub2e4.</p> </li> </ol> <ol> <li> <p>GitHub Pages \uc124\uc815</p> </li> <li> <p>GitHub \uc800\uc7a5\uc18c \u2192 Settings \u2192 Pages</p> </li> <li> <p>\u201cBranch\u201d \ud56d\ubaa9\uc5d0\uc11c \u201cgh-pages\u201d\ub97c \uc120\ud0dd \ud6c4 \u201cSave\u201d</p> </li> <li> <p>\uc7a0\uc2dc \uae30\ub2e4\ub9ac\uba74, \uc544\ub798\ucabd\uc5d0 \u201cYour site is published at ~~\u201d \ub77c\ub294 \ubb38\uad6c\uc640 \ud568\uaed8 \ub9c1\ud06c\uac00 \ud45c\uc2dc</p> </li> <li> <p>\ube0c\ub77c\uc6b0\uc800\uc5d0\uc11c \ud574\ub2f9 \ub9c1\ud06c(https://\uc0ac\uc6a9\uc790\uba85.github.io/\ub808\ud3ec\uba85/)\ub85c \uc811\uc18d\ud558\uba74 MkDocs \uc815\uc801 \uc0ac\uc774\ud2b8\uac00 \ubcf4\uc5ec\uc57c \ud569\ub2c8\ub2e4.</p> </li> </ol> <ol> <li> <p>\uc0ac\uc6a9 \uc2dc\ub098\ub9ac\uc624 \uc815\ub9ac</p> </li> <li> <p>\ubb38\uc11c \uc791\uc131 &amp; \uc218\uc815</p> </li> </ol> <p>docs/ \ud3f4\ub354\uc5d0 .md \ud30c\uc77c \uc791\uc131 (Front Matter, \ub0b4\uc6a9 \ub4f1)</p> <p>git add . &amp;&amp; git commit -m \"Update docs\" \u2192 git push origin main</p> <ol> <li>GitHub Actions \uc790\ub3d9 \ube4c\ub4dc</li> </ol> <p>Actions\uac00 pip install -r requirements.txt \u2192 mkdocs build \u2192 mkdocs gh-deploy --force</p> <p>gh-pages \ube0c\ub79c\uce58\uc5d0 \uc815\uc801 \ud30c\uc77c \ud478\uc2dc</p> <ol> <li>GitHub Pages \uc790\ub3d9 \uc5c5\ub370\uc774\ud2b8</li> </ol> <p>\uc0ac\uc6a9\uc790\ub294 \u201chttps://\uc0ac\uc6a9\uc790\uba85.github.io/\ub808\ud3ec\uba85/\u201d\ub85c \uc811\uc18d\ud558\uba74 \ud56d\uc0c1 \ucd5c\uc2e0 \ubb38\uc11c \ud655\uc778 \uac00\ub2a5</p> <ol> <li> <p>\uc720\uc758\uc0ac\ud56d &amp; \uc790\uc8fc \ubb3b\ub294 \uc9c8\ubb38</p> </li> <li> <p>Q. \u201cActions\uc5d0\uc11c \uad8c\ud55c \ubb38\uc81c \ubc1c\uc0dd!\u201d</p> </li> </ol> <p>\ubcf4\ud1b5 \ud37c\ube14\ub9ad \ub808\ud3ec\ub294 \ubb38\uc81c \uc5c6\uc9c0\ub9cc, \ud504\ub77c\uc774\ube57 \ub808\ud3ec\uc5d0\uc11c Pages\ub97c \uc4f0\ub824\uba74 GitHub \uc720\ub8cc \uc694\uae08\uc81c, \uadf8\ub9ac\uace0 Actions \uc124\uc815\uc5d0\uc11c \u201cAllow GitHub Actions to create and approve pull requests\u201d \ub4f1 \uad8c\ud55c \uc870\uc815\uc774 \ud544\uc694\ud560 \uc218 \uc788\uc74c</p> <p>\ub610\ub294 \u201cPage build and deployment\u201d \uad8c\ud55c\uc774 \ud544\uc694</p> <ol> <li>Q. \u201cmkdocs gh-deploy --force\u201d \uc368\uc57c \ud558\ub098\uc694?</li> </ol> <p>--force\ub294 \u201c\uc774\ubbf8 gh-pages \ube0c\ub79c\uce58\uac00 \uc788\uc5b4\ub3c4 \uac15\uc81c \ub36e\uc5b4\uc4f0\uae30\u201d \uc635\uc158\uc785\ub2c8\ub2e4. \ubcf4\ud1b5 \ucda9\ub3cc \ubc29\uc9c0 \uc6a9\ub3c4\ub85c \uc790\uc8fc \uc0ac\uc6a9</p> <ol> <li>Q. \ub85c\uceec\uc5d0\uc11c mkdocs gh-deploy \uc2e4\ud589\ud558\uba74 \uc548 \ub418\ub098\uc694?</li> </ol> <p>\uac00\ub2a5\ud558\uc9c0\ub9cc, Streamlit Cloud \ud658\uacbd\uc5d0\uc120 .git\uc774 \uc5c6\uc5b4\uc11c \uc2e4\ud328\ud569\ub2c8\ub2e4.</p> <p>GitHub Actions \uc790\ub3d9\ud654\uac00 \ud6e8\uc52c \ud3b8\ub9ac</p> <ol> <li>Q. \uc0ac\uc774\ud2b8 \uc8fc\uc18c\uac00 \ubcf5\uc7a1\ud558\uac70\ub098, \ucee4\uc2a4\ud140 \ub3c4\uba54\uc778 \uc4f0\uace0 \uc2f6\uc5b4\uc694.</li> </ol> <p>GitHub Pages\uc758 \u201cCustom domain\u201d \uae30\ub2a5 \uc0ac\uc6a9. \u201cSettings \u2192 Pages \u2192 Custom domain\u201d\uc5d0 \ub0b4 \ub3c4\uba54\uc778\uc744 \uc5f0\uacb0\ud558\uba74 \ub429\ub2c8\ub2e4.</p> <ol> <li>\uc694\uc57d</li> </ol> <p>\uc644\uc804 \ucd08\ubcf4\uc790\ub77c\uba74, GitHub Actions \uc124\uc815 \ud30c\uc77c(.github/workflows/mkdocs-deploy.yml)\ub9cc \ucd94\uac00\ud558\uba74 OK</p> <p>main \ube0c\ub79c\uce58\uc5d0 push \u2192 Actions\uac00 MkDocs \ube4c\ub4dc &amp; gh-deploy \u2192 GitHub Pages\uc5d0 \ucd5c\uc2e0 \ubb38\uc11c \uac8c\uc2dc \u2192 \uc0ac\uc774\ud2b8 \uc790\ub3d9 \uac31\uc2e0</p> <p>\uc751\uc6d0\uc758 \ub9d0 \"\ucc98\uc74c\uc5d4 \ubcf5\uc7a1\ud574 \ubcf4\uc774\uc9c0\ub9cc, \ud55c \ubc88 \uad6c\ucd95\ud574\ub450\uba74 \ub9e4\ubc88 \uc218\ub3d9\uc73c\ub85c \ubc30\ud3ec\ud560 \ud544\uc694 \uc5c6\uc774 \ubb38\uc11c\ub97c \uc218\uc815\ud560 \ub54c\ub9c8\ub2e4 \uc790\ub3d9\uc73c\ub85c GitHub Pages\uac00 \uc5c5\ub370\uc774\ud2b8\ub429\ub2c8\ub2e4. \uafb8\uc900\ud788 \uacbd\ud5d8\uc744 \uc313\uc73c\uba74 \ub354\uc6b1 \uc548\uc815\uc801\uc774\uace0 \ud6a8\uc728\uc801\uc778 \uac1c\ubc1c \ud750\ub984\uc744 \ub9cc\ub4e4 \uc218 \uc788\uc744 \uac70\uc608\uc694. \ud30c\uc774\ud305\uc785\ub2c8\ub2e4!\"</p>","tags":["mkdocs","githubActions","\uc790\ub3d9\ubc30\ud3ec","GitHub Pages","\ucd08\ubcf4\uc790"]},{"location":"2024-12-21-%234/#mkdocs-githubactions-cicd-beginnerfriendly","title":"mkdocs #githubActions #ci/cd #beginnerfriendly #\uc790\ub3d9\ubc30\ud3ec","text":"","tags":["mkdocs","githubActions","\uc790\ub3d9\ubc30\ud3ec","GitHub Pages","\ucd08\ubcf4\uc790"]}]}